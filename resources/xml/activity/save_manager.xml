<?xml version="1.0" encoding="UTF-8"?>
<brls:AppletFrame id="saveManagerFrame" title="@i18n/thomaz/saves/title" iconInterpolation="linear">
    <brls:Box axis="column" grow="1.0"
              paddingTop="32" paddingBottom="28" paddingLeft="48" paddingRight="48">

        <AnimatedBox axis="column" entranceDelay="0">
            <brls:Label text="@i18n/thomaz/saves/subtitle"
                        fontSize="16" textColor="@theme/thomaz/text_dim" marginBottom="16"/>
        </AnimatedBox>

        <brls:ProgressSpinner id="spinner" width="48" height="48"
                              marginTop="40" alignSelf="center"/>

        <brls:Label id="emptyLabel" text="@i18n/thomaz/saves/empty"
                    fontSize="18" textColor="@theme/thomaz/text_dim"
                    marginTop="40" alignSelf="center"
                    visibility="gone"/>

        <brls:ScrollingFrame grow="1.0">
            <AnimatedBox id="saveListBox" axis="column" grow="1.0" entranceDelay="80"/>
        </brls:ScrollingFrame>
    </brls:Box>
</brls:AppletFrame>
