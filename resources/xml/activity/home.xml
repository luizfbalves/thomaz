<?xml version="1.0" encoding="UTF-8"?>
<!--
  Home — "What are we doing today?" (design "Signal").
  Violet hero (Themes) + two card columns so the 5 other destinations no longer
  crowd a single rail: column A = Settings/Saves/Mods, column B = System/Cheats.
  Each block is an AnimatedBox so the menu cascades in on appear.
  Footer hints come from registerAction() in HomeActivity.
  IDs themesCard / settingsCard / savesCard / modsCard / systemCard / cheatsCard wired in HomeActivity.
-->
<brls:AppletFrame title="thomaz" iconInterpolation="linear">

    <brls:Box axis="column" grow="1.0"
              paddingTop="32" paddingBottom="28"
              paddingLeft="48" paddingRight="48">

        <!-- greeting -->
        <AnimatedBox axis="column" marginBottom="22" entranceDelay="0">
            <brls:Label text="@i18n/thomaz/home/eyebrow"
                        fontSize="16" textColor="@theme/thomaz/text_dim"/>
            <brls:Label text="@i18n/thomaz/home/greeting"
                        fontSize="34" textColor="@theme/thomaz/text" marginTop="6"/>
        </AnimatedBox>

        <!-- hero + two card columns (3 parts: hero | col A | col B) -->
        <brls:Box axis="row" grow="1.0">

            <!-- ===== HERO: Themes ===== -->
            <AnimatedBox id="themesCard" entranceDelay="80"
                      axis="column" grow="1.25" marginRight="18"
                      padding="34" cornerRadius="22"
                      backgroundColor="@theme/thomaz/accent_bright"
                      focusable="true" highlightCornerRadius="22"
                      hideHighlightBackground="true">

                <brls:Box grow="1.0"/>

                <brls:Label text="@i18n/themes/title"
                            fontSize="40" textColor="#FFFFFF"/>
                <brls:Label text="@i18n/themes/subtitle"
                            fontSize="17" textColor="#FFFFFFD9"
                            marginTop="8" width="300"/>
            </AnimatedBox>

            <!-- ===== COLUMN A: Settings / Saves / Mods ===== -->
            <brls:Box axis="column" grow="1.0" marginRight="14">

                <!-- Settings (active) -->
                <AnimatedBox id="settingsCard" entranceDelay="150"
                          axis="row" alignItems="center" grow="1.0" marginBottom="14"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_settings"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Label text="@i18n/thomaz/module/settings/title"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </AnimatedBox>

                <!-- Save Manager (active) -->
                <AnimatedBox id="savesCard" entranceDelay="210"
                          axis="row" alignItems="center" grow="1.0" marginBottom="14"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_backup"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Label text="@i18n/thomaz/saves/title"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </AnimatedBox>

                <!-- Mods (active) -->
                <AnimatedBox id="modsCard" entranceDelay="270"
                          axis="row" alignItems="center" grow="1.0"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_mods"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Label text="@i18n/thomaz/home/mods"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </AnimatedBox>

            </brls:Box>

            <!-- ===== COLUMN B: System / Cheats ===== -->
            <brls:Box axis="column" grow="1.0">

                <!-- Sistema (active) -->
                <AnimatedBox id="systemCard" entranceDelay="200"
                          axis="row" alignItems="center" grow="1.0" marginBottom="14"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_settings"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Label text="@i18n/system/home"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </AnimatedBox>

                <!-- Cheats (active) -->
                <AnimatedBox id="cheatsCard" entranceDelay="260"
                          axis="row" alignItems="center" grow="1.0"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/accent_bright"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Label text="@i18n/thomaz/module/cheats/title"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </AnimatedBox>

            </brls:Box>
        </brls:Box>
    </brls:Box>
</brls:AppletFrame>
