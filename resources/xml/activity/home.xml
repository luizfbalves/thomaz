<?xml version="1.0" encoding="UTF-8"?>
<!--
  Home — "What are we doing today?" (design "Signal").
  Big violet hero (Cheats) + vertical rail (Settings + coming soon).
  Footer hints come from registerAction() in HomeActivity.
  IDs feedCard / cheatsCard / settingsCard wired in HomeActivity.
-->
<brls:AppletFrame title="thomaz" iconInterpolation="linear">

    <brls:Box axis="column" grow="1.0"
              paddingTop="36" paddingBottom="28"
              paddingLeft="56" paddingRight="56">

        <!-- greeting -->
        <brls:Box axis="column" marginBottom="22">
            <brls:Label text="@i18n/thomaz/home/eyebrow"
                        fontSize="16" textColor="@theme/thomaz/text_dim"/>
            <brls:Label text="@i18n/thomaz/home/greeting"
                        fontSize="34" textColor="@theme/thomaz/text" marginTop="6"/>
        </brls:Box>

        <!-- hero + rail -->
        <brls:Box axis="row" grow="1.0">

            <!-- ===== HERO: Feed ===== -->
            <brls:Box id="feedCard"
                      axis="column" grow="1.55" marginRight="18"
                      padding="34" cornerRadius="22"
                      backgroundColor="@theme/thomaz/tile_cheats"
                      focusable="true" highlightCornerRadius="22"
                      hideHighlightBackground="true">

                <brls:Box width="64" height="64" cornerRadius="18"
                          backgroundColor="#FFFFFF29"
                          justifyContent="center" alignItems="center">
                    <brls:Label text="@i18n/thomaz/icon/cheats"
                                fontSize="36" textColor="#FFFFFF"/>
                </brls:Box>

                <brls:Box grow="1.0"/>

                <brls:Label text="@i18n/thomaz/module/feed/title"
                            fontSize="40" textColor="#FFFFFF"/>
                <brls:Label text="@i18n/thomaz/module/feed/subtitle"
                            fontSize="17" textColor="#FFFFFFD9"
                            marginTop="8" width="360"/>
            </brls:Box>

            <!-- ===== RAIL ===== -->
            <brls:Box axis="column" grow="1.0">

                <!-- Settings (active) -->
                <brls:Box id="settingsCard"
                          axis="row" alignItems="center" grow="1.0" marginBottom="14"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_settings"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Box width="44" height="44" cornerRadius="12"
                              backgroundColor="#FFFFFF29"
                              justifyContent="center" alignItems="center" marginRight="16">
                        <brls:Label text="@i18n/thomaz/icon/settings"
                                    fontSize="24" textColor="#FFFFFF"/>
                    </brls:Box>
                    <brls:Label text="@i18n/thomaz/module/settings/title"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </brls:Box>

                <!-- Cheats (ativo) — antes era o slot do Save Manager -->
                <brls:Box id="cheatsCard"
                          axis="row" alignItems="center" grow="1.0" marginBottom="14"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_saves"
                          focusable="true" highlightCornerRadius="16"
                          hideHighlightBackground="true">
                    <brls:Box width="44" height="44" cornerRadius="12"
                              backgroundColor="#FFFFFF29"
                              justifyContent="center" alignItems="center" marginRight="16">
                        <brls:Label text="@i18n/thomaz/icon/cheats"
                                    fontSize="24" textColor="#FFFFFF"/>
                    </brls:Box>
                    <brls:Label text="@i18n/thomaz/module/cheats/title"
                                fontSize="17" textColor="#FFFFFF" grow="1.0"/>
                </brls:Box>

                <!-- Mods (coming soon) -->
                <brls:Box axis="row" alignItems="center" grow="1.0"
                          paddingLeft="22" paddingRight="22" cornerRadius="16"
                          backgroundColor="@theme/thomaz/tile_mods">
                    <brls:Box width="44" height="44" cornerRadius="12"
                              backgroundColor="#FFFFFF29"
                              justifyContent="center" alignItems="center" marginRight="16">
                        <brls:Label text="@i18n/thomaz/icon/mods"
                                    fontSize="24" textColor="#FFFFFFD9"/>
                    </brls:Box>
                    <brls:Box axis="column" grow="1.0">
                        <brls:Label text="@i18n/thomaz/home/mods"
                                    fontSize="17" textColor="#FFFFFF"/>
                        <brls:Label text="@i18n/thomaz/common/coming_soon"
                                    fontSize="11" textColor="#FFFFFFB3" marginTop="3"/>
                    </brls:Box>
                    <brls:Label text="@i18n/thomaz/icon/lock"
                                fontSize="20" textColor="#FFFFFFB3"/>
                </brls:Box>

            </brls:Box>
        </brls:Box>
    </brls:Box>
</brls:AppletFrame>
