<?xml version="1.0" encoding="UTF-8"?>
<!--
  Cheat detail — per-game toggles (design "Signal").
  Violet hero (icon + game name) above the status line, spinner and the
  cheat toggle list. IDs (gameTitle/statusLabel/spinner/cheatListBox/cheatFrame)
  are kept so CheatDetailActivity wiring is unchanged.
-->
<brls:AppletFrame id="cheatFrame"
    title="@i18n/thomaz/cheats/title"
    iconInterpolation="linear">

    <brls:ScrollingFrame width="auto" height="auto" grow="1.0">

        <brls:Box width="auto" height="auto" axis="column"
                  paddingTop="32" paddingLeft="48" paddingRight="48" paddingBottom="28">

            <!-- hero: rounded game-name banner (solid bg so cornerRadius rounds) -->
            <AnimatedBox axis="row" alignItems="center" entranceDelay="0"
                      padding="20" cornerRadius="16"
                      backgroundColor="@theme/thomaz/accent_bright"
                      marginBottom="18">
                <brls:Label id="gameTitle"
                            width="auto" height="auto" grow="1.0"
                            fontSize="26" textColor="#FFFFFF"/>
            </AnimatedBox>

            <!-- loading / fallback / empty / error -->
            <brls:Label id="statusLabel"
                        width="auto" height="auto"
                        text="@i18n/thomaz/cheats/loading"
                        fontSize="16" textColor="@theme/thomaz/text_dim"
                        marginBottom="14"/>

            <brls:ProgressSpinner id="spinner"
                        width="44" height="44" marginTop="8" marginBottom="8"/>

            <!-- cheat toggles inserted by CheatDetailActivity -->
            <AnimatedBox id="cheatListBox" entranceDelay="80"
                      width="auto" height="auto" axis="column"/>

        </brls:Box>

    </brls:ScrollingFrame>

</brls:AppletFrame>
