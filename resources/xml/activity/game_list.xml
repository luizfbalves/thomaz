<brls:AppletFrame title="@i18n/thomaz/games/title"
    iconInterpolation="linear">

    <brls:ScrollingFrame
        width="auto"
        height="auto"
        grow="1.0">

        <brls:Box
            width="auto"
            height="auto"
            axis="column"
            paddingTop="20"
            paddingLeft="60"
            paddingRight="60"
            paddingBottom="20">

            <!-- Loading spinner: reading each title's control data off the NAND
                 is slow, so GameListActivity does it on a worker thread and
                 shows this until the rows are ready, then hides it. -->
            <brls:ProgressSpinner
                id="spinner"
                width="44" height="44"
                marginTop="24"
                alignSelf="center" />

            <!-- Empty state label (shown when no titles are found). Hidden
                 initially so it doesn't flash before the load finishes. -->
            <brls:Label
                id="emptyLabel"
                width="auto"
                height="auto"
                visibility="gone"
                text="@i18n/thomaz/games/empty"
                fontSize="18"
                horizontalAlign="center" />

            <!-- Dynamic list of game rows inserted by GameListActivity -->
            <brls:Box
                id="gameListBox"
                width="auto"
                height="auto"
                axis="column" />

        </brls:Box>

    </brls:ScrollingFrame>

</brls:AppletFrame>
