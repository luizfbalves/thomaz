<?xml version="1.0" encoding="UTF-8"?>
<brls:AppletFrame title="@i18n/thomaz/saves/title" iconInterpolation="linear">
    <brls:Box axis="row" grow="1.0"
              paddingTop="28" paddingBottom="24" paddingLeft="40" paddingRight="40">

        <!-- ===== LEFT: game panel (icon + metadata) ===== -->
        <brls:Box axis="column" width="300" marginRight="28">
            <brls:Box id="gameIconPlaceholder" width="220" height="220" cornerRadius="20"
                      justifyContent="center" alignItems="center" marginBottom="14"
                      backgroundColor="@theme/thomaz/accent_bright">
                <brls:Label id="gameIconLetter" text="?" fontSize="120" textColor="#FFFFFF"/>
            </brls:Box>
            <brls:Image id="gameIcon" width="220" height="220" cornerRadius="20"
                        marginBottom="14" visibility="gone"/>

            <brls:Label id="gamePanelName" text="" fontSize="23"
                        textColor="@theme/thomaz/text" marginBottom="14"/>

            <brls:Box axis="column" marginBottom="9">
                <brls:Label text="@i18n/thomaz/gameinfo/publisher" fontSize="12"
                            textColor="@theme/thomaz/text_dim"/>
                <brls:Label id="metaPublisher" text="" fontSize="15"
                            textColor="@theme/thomaz/text"/>
            </brls:Box>
            <brls:Box axis="column" marginBottom="9">
                <brls:Label text="@i18n/thomaz/gameinfo/version" fontSize="12"
                            textColor="@theme/thomaz/text_dim"/>
                <brls:Label id="metaVersion" text="" fontSize="15"
                            textColor="@theme/thomaz/text"/>
            </brls:Box>
            <brls:Box axis="column" marginBottom="9">
                <brls:Label text="@i18n/thomaz/gameinfo/playtime" fontSize="12"
                            textColor="@theme/thomaz/text_dim"/>
                <brls:Label id="metaPlaytime" text="" fontSize="15"
                            textColor="@theme/thomaz/text"/>
            </brls:Box>
            <brls:Box axis="column" marginBottom="9">
                <brls:Label text="@i18n/thomaz/gameinfo/last_played" fontSize="12"
                            textColor="@theme/thomaz/text_dim"/>
                <brls:Label id="metaLastPlayed" text="" fontSize="15"
                            textColor="@theme/thomaz/text"/>
            </brls:Box>
            <brls:Box axis="column" marginBottom="9">
                <brls:Label text="@i18n/thomaz/gameinfo/save_size" fontSize="12"
                            textColor="@theme/thomaz/text_dim"/>
                <brls:Label id="metaSaveSize" text="" fontSize="15"
                            textColor="@theme/thomaz/text"/>
            </brls:Box>
            <brls:Box axis="column">
                <brls:Label text="@i18n/thomaz/gameinfo/title_id" fontSize="12"
                            textColor="@theme/thomaz/text_dim"/>
                <brls:Label id="metaTitleId" text="" fontSize="14"
                            textColor="@theme/thomaz/text_dim"/>
            </brls:Box>
        </brls:Box>

        <!-- ===== RIGHT: actions + history ===== -->
        <brls:Box axis="column" grow="1.0">
            <brls:Label id="lastBackup" text="" fontSize="15"
                        textColor="@theme/thomaz/text_dim" marginBottom="14"/>

            <brls:Box id="backupButton" axis="row" alignItems="center" justifyContent="center"
                      height="56" cornerRadius="14" focusable="true"
                      backgroundColor="@theme/thomaz/tile_saves" marginBottom="18">
                <brls:Label text="@i18n/thomaz/saves/action_backup"
                            fontSize="18" textColor="#FFFFFF"/>
            </brls:Box>

            <brls:Label text="@i18n/thomaz/saves/cloud_section"
                        fontSize="15" textColor="@theme/thomaz/text_dim" marginBottom="8"/>
            <brls:Label id="cloudStatus" text="" fontSize="14"
                        textColor="@theme/thomaz/text_dim" marginBottom="10"/>
            <brls:Box id="cloudButtons" axis="row" visibility="gone" marginBottom="18">
                <brls:Box id="cloudUpload" axis="row" alignItems="center" justifyContent="center"
                          height="48" grow="1.0" cornerRadius="12" focusable="true"
                          backgroundColor="@theme/thomaz/tile_saves" marginRight="8">
                    <brls:Label text="@i18n/thomaz/saves/cloud_upload"
                                fontSize="16" textColor="#FFFFFF"/>
                </brls:Box>
                <brls:Box id="cloudDownload" axis="row" alignItems="center" justifyContent="center"
                          height="48" grow="1.0" cornerRadius="12" focusable="true"
                          backgroundColor="@theme/thomaz/surface_2" marginLeft="8">
                    <brls:Label text="@i18n/thomaz/saves/cloud_download"
                                fontSize="16" textColor="@theme/thomaz/text"/>
                </brls:Box>
            </brls:Box>
            <brls:Box id="cloudLogin" axis="row" alignItems="center" justifyContent="center"
                      height="48" cornerRadius="12" focusable="true" visibility="gone"
                      backgroundColor="@theme/thomaz/surface_2" marginBottom="18">
                <brls:Label text="@i18n/thomaz/saves/cloud_login"
                            fontSize="16" textColor="@theme/thomaz/text"/>
            </brls:Box>

            <brls:Label text="@i18n/thomaz/saves/history"
                        fontSize="15" textColor="@theme/thomaz/text_dim" marginBottom="8"/>
            <brls:ProgressSpinner id="spinner" width="36" height="36" visibility="gone" alignSelf="center"/>
            <brls:ScrollingFrame grow="1.0">
                <brls:Box id="historyBox" axis="column" grow="1.0"/>
            </brls:ScrollingFrame>
        </brls:Box>
    </brls:Box>
</brls:AppletFrame>
