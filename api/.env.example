# Copy to .env and adjust. Never commit .env.

DATABASE_URL="postgresql://thomaz:thomaz@localhost:5433/thomaz?schema=public"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
PORT=3000
HOST=0.0.0.0
# Public base URL for imageUrl in feed responses (no trailing slash)
PUBLIC_BASE_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
# Comma-separated origins for CORS (dev)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Access JWT lifetime (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES="15m"
# Refresh token TTL in days
REFRESH_TOKEN_TTL_DAYS=7
# Max requests/minute per IP on /auth/login and /auth/register (brute-force / signup-spam guard)
AUTH_RATE_MAX=10
