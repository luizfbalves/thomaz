# Resources: Borealis's runtime resources (fonts, material, shaders, demo
# strings/xml) are merged in from lib/borealis/resources at build time
# (CI + scripts/build-desktop.sh). Track ONLY our authored files.
/resources/**
!/resources/i18n/
!/resources/i18n/en-US/
!/resources/i18n/pt-BR/
!/resources/i18n/fr/
!/resources/i18n/ru/
!/resources/i18n/zh-Hans/
