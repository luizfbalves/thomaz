!/resources/i18n/pt-BR/thomaz.json
!/resources/i18n/fr/thomaz.json
!/resources/i18n/ru/thomaz.json
!/resources/i18n/zh-Hans/thomaz.json
!/resources/img/
!/resources/img/icon.jpg
!/resources/xml/
!/resources/xml/activity/
